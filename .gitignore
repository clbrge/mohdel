# ── Dependency + build caches ────────────────────────────────────────
# npm package store (regenerated by `npm install`).
/node_modules/
# Rust cargo build output (`cargo build` / `cargo test`).
/target/
# Generic tool cache dir (release-it, vitest, etc.).
.cache/

# ── Native addon artifacts ───────────────────────────────────────────
# Compiled native addons (rust/napi-addon → *.node). Platform-specific,
# produced by `node-gyp` / `napi-rs` at build time — never committed.
*.node

# ── Private project instructions ─────────────────────────────────────
# Agent-specific guidance files (claude.ai, OpenAI Codex). Not part of
# the public package surface; kept local to each contributor's checkout.
CLAUDE.md
AGENTS.md

# ── Platform-specific sub-package binaries ───────────────────────────
# Prebuilt thin-gate binaries (`packages/mohdel-thin-gate-<platform>/bin/`)
# are staged here by CI before `npm publish` and never checked in —
# each tag builds fresh from the Rust source under `rust/thin-gate/`.
packages/*/bin/

# ── Environment / secrets ────────────────────────────────────────────
# Never commit API keys. Mohdel loads provider keys from
# `~/.config/mohdel/environment` (XDG), so a `.env` in the repo root
# would be a user mistake — catch it defensively.
.env
.env.*
!.env.example

# ── Editor / OS noise ────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ── Logs ─────────────────────────────────────────────────────────────
# npm writes `npm-debug.log*` into cwd on install failure; ad-hoc
# runtime logs (`*.log`) accumulate from local scripts.
*.log
npm-debug.log*
probes/
